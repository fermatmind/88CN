{
  "version": "0.1.0",
  "policy": {
    "default_allow_install": false,
    "default_allow_network": false,
    "default_allow_write": false,
    "default_allow_secrets": false,
    "global_install_requires_human": true,
    "browser_extensions_denied_by_default": true,
    "mcp_servers_denied_by_default": true,
    "production_credentials_denied": true
  },
  "tools": [
    {
      "id": "git",
      "name": "Git",
      "type": "vcs",
      "status": "approved",
      "phases": ["OPS", "QA", "PR31-PR121"],
      "required": true,
      "install": { "mode": "preinstalled", "command": "" },
      "permissions": { "network": true, "write": true, "secrets": false },
      "allowed_commands": ["git status", "git diff", "git fetch", "git pull", "git checkout", "git switch", "git add", "git commit", "git push", "git log", "git branch"],
      "forbidden_commands": ["git filter-branch with secret material", "git push --force without explicit task approval"],
      "notes": "Allowed across all phases; no secret access."
    },
    {
      "id": "gh",
      "name": "GitHub CLI",
      "type": "repo",
      "status": "approved",
      "phases": ["OPS", "QA", "PR tasks"],
      "required": true,
      "install": { "mode": "preinstalled", "command": "" },
      "permissions": { "network": true, "write": true, "secrets": false },
      "allowed_commands": ["gh pr list", "gh pr view", "gh pr create", "gh pr checks", "gh pr merge"],
      "forbidden_commands": ["gh secret", "gh repo delete"],
      "notes": "Use for PR inspection, draft PR creation, checks, and policy-gated PR merge. Merge execution requires mergeability, passing required checks, and no bypass of human checkpoints."
    },
    {
      "id": "node",
      "name": "Node.js",
      "type": "runtime",
      "status": "approved",
      "phases": ["OPS", "QA", "PR31-PR121"],
      "required": true,
      "install": { "mode": "preinstalled", "command": "" },
      "permissions": { "network": false, "write": true, "secrets": false },
      "allowed_commands": ["node scripts/*.mjs", "node scripts/agent/*.mjs"],
      "forbidden_commands": ["node -e network write with credentials"],
      "notes": "Allowed for repo-local scripts."
    },
    {
      "id": "npm",
      "name": "npm",
      "type": "package-manager",
      "status": "approved",
      "phases": ["OPS", "QA", "PR31-PR121"],
      "required": true,
      "install": { "mode": "project", "command": "npm ci" },
      "permissions": { "network": true, "write": true, "secrets": false },
      "allowed_commands": ["npm run", "npm ci"],
      "forbidden_commands": ["npm install -g", "npm install unless roadmap permits dependency changes"],
      "notes": "Dependency changes require a scoped PR and lockfile review."
    },
    {
      "id": "curl",
      "name": "curl",
      "type": "http-client",
      "status": "approved",
      "phases": ["OPS", "QA", "smoke"],
      "required": false,
      "install": { "mode": "system", "command": "" },
      "permissions": { "network": true, "write": false, "secrets": false },
      "allowed_commands": ["curl -I", "curl -sS", "curl -X GET", "curl -X POST test payloads"],
      "forbidden_commands": ["curl pipe bash", "curl pipe sh", "bash process substitution curl", "sh process substitution curl"],
      "notes": "Read-only smoke and API checks only."
    },
    {
      "id": "playwright",
      "name": "Playwright",
      "type": "browser-automation",
      "status": "conditional",
      "phases": ["PR35-PR46 visual QA", "explicit browser QA"],
      "required": false,
      "install": { "mode": "roadmap-permission-required", "command": "" },
      "permissions": { "network": true, "write": true, "secrets": false },
      "allowed_commands": ["playwright test with clean profile", "browser screenshots for QA"],
      "forbidden_commands": ["read user browser profile", "read cookies", "read passwords"],
      "notes": "Install requires explicit roadmap permission."
    },
    {
      "id": "supabase-cli",
      "name": "Supabase CLI",
      "type": "database-cli",
      "status": "conditional",
      "phases": ["DB validation", "migration review", "local validation"],
      "required": false,
      "install": { "mode": "human-approved", "command": "" },
      "permissions": { "network": true, "write": false, "secrets": false },
      "allowed_commands": ["supabase migration list local", "supabase db lint local"],
      "forbidden_commands": ["production database write", "production project link by Codex"],
      "notes": "Production DB access requires explicit human approval outside Codex."
    },
    {
      "id": "stripe-cli",
      "name": "Stripe CLI",
      "type": "payment-cli",
      "status": "conditional",
      "phases": ["PR50-PR51 test-mode payment QA"],
      "required": false,
      "install": { "mode": "human-approved", "command": "" },
      "permissions": { "network": true, "write": false, "secrets": false },
      "allowed_commands": ["stripe listen test mode", "stripe trigger test events"],
      "forbidden_commands": ["live mode", "real payment creation"],
      "notes": "Only future test-mode work; live operations are forbidden."
    },
    {
      "id": "composer",
      "name": "Composer",
      "type": "php-package-manager",
      "status": "conditional",
      "phases": ["PR81+ Laravel API Gateway"],
      "required": false,
      "install": { "mode": "future-roadmap", "command": "" },
      "permissions": { "network": true, "write": true, "secrets": false },
      "allowed_commands": ["composer install", "composer validate"],
      "forbidden_commands": ["global install without task permission"],
      "notes": "Not required now."
    },
    {
      "id": "php",
      "name": "PHP",
      "type": "runtime",
      "status": "conditional",
      "phases": ["PR81+ Laravel API Gateway"],
      "required": false,
      "install": { "mode": "future-roadmap", "command": "" },
      "permissions": { "network": false, "write": true, "secrets": false },
      "allowed_commands": ["php -v", "php artisan test in future Laravel repo"],
      "forbidden_commands": ["production artisan mutation without approval"],
      "notes": "Not required now."
    },
    {
      "id": "phpunit",
      "name": "PHPUnit",
      "type": "test-runner",
      "status": "conditional",
      "phases": ["PR81+ Laravel API Gateway"],
      "required": false,
      "install": { "mode": "future-roadmap", "command": "" },
      "permissions": { "network": false, "write": false, "secrets": false },
      "allowed_commands": ["phpunit", "vendor/bin/phpunit"],
      "forbidden_commands": ["tests that require production credentials"],
      "notes": "Not required now."
    },
    {
      "id": "redis-cli",
      "name": "Redis CLI",
      "type": "cache-cli",
      "status": "conditional",
      "phases": ["future Redis local diagnostics"],
      "required": false,
      "install": { "mode": "future-roadmap", "command": "" },
      "permissions": { "network": true, "write": false, "secrets": false },
      "allowed_commands": ["redis-cli ping local", "redis-cli info local"],
      "forbidden_commands": ["production Redis access", "flushall", "flushdb"],
      "notes": "Production Redis access requires explicit approval."
    },
    {
      "id": "openapi-validator",
      "name": "OpenAPI Validator",
      "type": "schema-validator",
      "status": "conditional",
      "phases": ["future Public API", "future B2B feed"],
      "required": false,
      "install": { "mode": "future-roadmap", "command": "" },
      "permissions": { "network": false, "write": false, "secrets": false },
      "allowed_commands": ["validate local OpenAPI files"],
      "forbidden_commands": ["install during OPS2"],
      "notes": "No install now."
    },
    {
      "id": "mcp-local-client",
      "name": "MCP Local Client",
      "type": "mcp-client",
      "status": "conditional",
      "phases": ["future MCP QA"],
      "required": false,
      "install": { "mode": "future-roadmap", "command": "" },
      "permissions": { "network": false, "write": false, "secrets": false },
      "allowed_commands": ["local MCP conformance checks"],
      "forbidden_commands": ["external MCP server connection now"],
      "notes": "No external MCP server now."
    }
  ],
  "denied": [
    "browser-cookie-reader",
    "password-manager-reader",
    "seo-rank-tracker",
    "auto-social-poster",
    "cloud-provider-write-plugin",
    "stripe-live-payment-plugin",
    "supabase-production-write-plugin",
    "unrestricted-filesystem-mcp",
    "browser-extension-installer",
    "keychain-reader",
    "email-blast-plugin",
    "social-dm-automation-plugin"
  ]
}
