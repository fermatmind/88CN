# 88CN Environment Variables
# Copy to .env.local for local development — DO NOT commit .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role key (admin operations only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Application
APP_URL=http://localhost:3000

# 88cn-index-data Integration
INDEX_DATA_GITHUB_OWNER=fermatmind
INDEX_DATA_GITHUB_REPO=88cn-index-data
INDEX_DATA_GITHUB_BRANCH=main
# INDEX_DATA_GITHUB_TOKEN=     # optional, server-only, never use NEXT_PUBLIC_ prefix
INDEX_DATA_LOCAL_PATH=../88cn-index-data
