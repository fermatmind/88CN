    "agent:mcp-config:check": "node scripts/agent/mcp-config-check.mjs",
    "agent:plugin-policy:check": "node scripts/agent/plugin-policy-check.mjs",
    "agent:pr:summary": "node scripts/agent/pr-summary.mjs",
    "docs:check": "node -e \"const fs=require('fs'); const files=['AGENTS.md','README.md','.gitignore','package.json','docs/00_PROJECT_BRIEF.md','docs/01_AGENT_OPERATING_MODEL.md','docs/02_ZERO_STATE_BOOTSTRAP.md','docs/06_FORBIDDEN_PATTERNS.md','docs/07_RUNTIME_GUARDS.md','docs/08_BATCH_PIPELINE.md','docs/09_EDITORIAL_PIPELINE.md','docs/10_DATA_CONTRACT.md','docs/DAY0_AUDIT.md','docs/11_SCALABILITY_GUARDS.md','docs/12_CACHE_AND_SITEMAP_STRATEGY.md','docs/13_COST_GUARDS.md','docs/14_OPEN_SOURCE_REUSE_POLICY.md','docs/RISK_ACCEPTANCE_LOG.md','docs/TASK_STATUS.md','docs/QA_REPORT.md','docs/VISUAL_BUGS.md','docs/FLOW_BUGS.md','docs/BUILD_ERRORS.md','third_party/NOTICE.md','screenshots/qa/.gitkeep','scripts/scan-forbidden-patterns.mjs','scripts/check-third-party-notices.mjs','scripts/codex-preflight.sh']; const missing=files.filter((file)=>!fs.existsSync(file)); if (missing.length) { console.error('Missing required files:\\n'+missing.join('\\n')); process.exit(1); } console.log('docs:check passed');\"",
