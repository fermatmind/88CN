{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://88cn.com/contracts/agent/review-blocked-record.schema.json",
  "title": "88CN Review Blocked Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_name",
    "slug_candidate",
    "blocker_codes",
    "source_stage",
    "observed_at",
    "human_unblock_required"
  ],
  "properties": {
    "project_name": { "type": "string", "minLength": 1 },
    "slug_candidate": { "type": "string" },
    "blocker_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "missing_official_source",
          "directory_hint_only",
          "canonical_ambiguous",
          "duplicate_conflict",
          "http_unreachable",
          "waf_or_blocked",
          "docs_missing",
          "github_mismatch",
          "copied_content_risk",
          "pii_or_private_data_risk",
          "manual_review_required"
        ]
      }
    },
    "source_stage": {
      "enum": ["discovery_hint", "source_verified", "canonical_candidate", "audit_observed", "review_ready"]
    },
    "observed_at": { "type": "string", "format": "date-time" },
    "human_unblock_required": { "const": true },
    "admin_only_summary": { "type": "string" }
  }
}
