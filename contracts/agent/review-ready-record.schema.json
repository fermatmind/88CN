{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://88cn.com/contracts/agent/review-ready-record.schema.json",
  "title": "88CN Review Ready Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_name",
    "slug_candidate",
    "official_website_url",
    "source_status",
    "canonical_status",
    "audit_status",
    "recommendation",
    "review_blockers",
    "source_links",
    "public_field_candidates",
    "worker_trace"
  ],
  "properties": {
    "project_name": { "type": "string", "minLength": 1 },
    "slug_candidate": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "official_website_url": {
      "type": "string",
      "pattern": "^https?://"
    },
    "source_status": {
      "enum": ["source_verified", "source_needs_review"]
    },
    "canonical_status": {
      "enum": ["canonical_candidate", "canonical_resolved", "canonical_needs_review"]
    },
    "audit_status": {
      "enum": ["audit_observed", "audit_not_run", "audit_needs_review"]
    },
    "recommendation": {
      "enum": [
        "recommend_publish",
        "recommend_review",
        "recommend_quarantine",
        "recommend_reject",
        "recommend_recheck"
      ]
    },
    "review_blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url", "source_type"],
        "properties": {
          "url": { "type": "string", "pattern": "^https?://" },
          "source_type": {
            "enum": ["official_site", "github", "docs", "pricing", "launch", "other_public_source"]
          }
        }
      }
    },
    "public_field_candidates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string" },
        "project_name": { "type": "string" },
        "original_summary": { "type": "string" },
        "official_website_url": { "type": "string" },
        "github_url": { "type": ["string", "null"] },
        "docs_url": { "type": ["string", "null"] },
        "primary_category": { "type": "string" },
        "collection_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "public_signal_chips": {
          "type": "array",
          "items": { "type": "string" }
        },
        "last_reviewed_at": { "type": "string" }
      }
    },
    "worker_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["worker_repo_sha", "run_id", "trace_id"],
      "properties": {
        "worker_repo_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "run_id": { "type": "string" },
        "trace_id": { "type": "string" }
      }
    },
    "github_url": { "type": ["string", "null"] },
    "docs_url": { "type": ["string", "null"] },
    "primary_category": { "type": "string" },
    "collection_tag_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "public_signal_chip_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "original_summary_candidate": { "type": "string" },
    "last_observed_at": { "type": "string", "format": "date-time" }
  }
}
